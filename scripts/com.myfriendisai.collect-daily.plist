<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.myfriendisai.collect-daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/walker/Projects/myfriendisai/scripts/run_collect.sh</string>
    </array>

    <!-- Run daily at 06:00 local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/walker/Projects/myfriendisai/logs/launchd_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/walker/Projects/myfriendisai/logs/launchd_stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/walker/Projects/myfriendisai</string>
</dict>
</plist>
